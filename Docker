yum install docker -y

systemctl start docker

docker version #client and server status

docker --version #docker version 

docker pull <image> 

docker images

docker run -it <imagename>    #run interactive mode

ps aux #to check running process inside docker

docker ps #to check running container 

docker ps -a #both running and exited

docker ps -a | grep Exited  # exited  

exit  #kill existing process and exited from container 

ctrl pq  # exit without kill running process 

docker exec -it <containerID>  /bin/bash

docker run -dt #only create container but not login

docker inspect <imagename>
