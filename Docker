yum install docker -y         #It installs Docker on your system

systemctl start docker        #This command is used to start the Docker service on a Linux system.

docker version                #This command shows the version details of Docker and the status of both: Client & Server 

docker --version              #This command shows the installed version of Docker (client only).

docker pull <image>           #This command is used to download a Docker image from a container registry (usually Docker Hub) to your local machine.

docker images                 #This command lists all the Docker images stored locally on your system.

docker run -it <imagename>    #This command creates and starts a container interactively from a Docker image. In simple terms:
                              #It runs a container and lets you directly interact with it via terminal.

ps aux                        #This command shows all running processes on your Linux system. 
                              #It gives a detailed snapshot of everything currently running — system services, apps, background tasks, etc.

docker ps                     #This command lists all currently running containers on your system.

docker ps -a                  #This command lists all containers on your system — including:Running containers, Stopped (exited) containers, Created but not started containers
                              #It’s the complete history of containers on your machine.

docker ps -a | grep Exited    #This command shows only the containers that have stopped (Exited state).  

exit  #kill existing process and exited from container 

ctrl pq  # exit without kill running process 

docker exec -it <containerID>  /bin/bash #login to docker

docker run -dt #only create container but not login

docker inspect <imagename>
